# Copy this file to .env and fill in your values.
# Never commit .env to git.

ANTHROPIC_API_KEY=sk-ant-...

# Optional model overrides (defaults shown)
VOICE_MODEL=claude-haiku-4-5-20251001
READINESS_MODEL=claude-haiku-4-5-20251001
KEEPER_MODEL=claude-haiku-4-5-20251001

# Watcher: ms after last file change before batch flushes (default 30s)
WATCHER_BATCH_QUIET_MS=30000
